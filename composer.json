{
  "name": "mddejong/emc-skin-module",
  "description": "Code and layout for the Erasmus MC GemsTracker projects",
  "type": "library",
  "license": "No free license, do not copy",
  "require": {
    "php": ">=8.2.0",
    "gemstracker/gemstracker": "2.x-dev",
    "gemstracker/ls6-basic-themes": "dev-main",
    "magnafacta/zalt-laminas-validator": "^1.0.5",
    "magnafacta/zalt-model": "^2.0.11",
    "magnafacta/zalt-util": "^1.0.5",
    "phpoffice/phpword": "^1.3.0"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^10.1"
  },
  "authors": [
    {
      "name": "Matijs de Jong",
      "email": "mjong@magnafacta.nl"
    }
  ],
  "minimum-stability": "dev",
  "config": {
    "sort-packages": true
  },
  "autoload": {
    "psr-4": {
      "EmcModule\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "EmcModule\\Test\\": "test\\"
    }
  },
  "repositories": [
    {
      "type": "git",
      "url": "https://github.com/gemstracker/gems-api.git"
    },
    {
      "type": "git",
      "url": "https://github.com/gemstracker/gems-fhir-api.git"
    },
    {
      "type": "git",
      "url": "https://github.com/gemstracker/gems-oauth2.git"
    },
    {
      "type": "git",
      "url": "https://github.com/GemsTracker/ls6-basic-themes.git"
    },
    {
      "type": "git",
      "url": "https://github.com/MagnaFacta/zalt-html.git"
    },
    {
      "type": "git",
      "url": "https://github.com/MagnaFacta/zalt-laminas-filter.git"
    },
    {
      "type": "git",
      "url": "https://github.com/MagnaFacta/zalt-laminas-validator.git"
    },
    {
      "type": "git",
      "url": "https://github.com/MagnaFacta/zalt-late.git"
    },
    {
      "type": "git",
      "url": "https://github.com/MagnaFacta/zalt-loader.git"
    },
    {
      "type": "git",
      "url": "https://github.com/MagnaFacta/zalt-model.git"
    },
    {
      "type": "git",
      "url": "https://github.com/MagnaFacta/zalt-util.git"
    }
  ],
  "scripts": {
    "test": [
      "@putenv XDEBUG_MODE=coverage",
      "vendor/bin/phpunit --configuration test/phpunit.xml test"
    ],
    "stan": [
      "vendor/bin/phpstan --memory-limit=512M"
    ]
  }
}
